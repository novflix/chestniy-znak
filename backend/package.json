{
  "name": "chestnyznak-backend",
  "version": "2.0.0",
  "description": "«Честный знак» — система маркировки товаров",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev":   "nodemon src/index.js",
    "seed":  "node src/config/seed.js",
    "test":  "jest --forceExit --runInBand"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "bcryptjs":              "^2.4.3",
    "cookie-parser":         "^1.4.6",
    "cors":                  "^2.8.5",
    "dotenv":                "^16.3.1",
    "express":               "^4.18.2",
    "express-validator":     "^7.0.1",
    "jsonwebtoken":          "^9.0.2",
    "uuid":                  "^9.0.0"
  },
  "devDependencies": {
    "jest":      "^29.7.0",
    "nodemon":   "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
